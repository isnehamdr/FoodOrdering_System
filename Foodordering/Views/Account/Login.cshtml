@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h3 class="text-center mb-4">Login to Fastos</h3>

                    <form>
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" placeholder="you@example.com" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input type="password" class="form-control" placeholder="Enter password" />
                        </div>

                        <button type="button" class="btn btn-warning w-100 py-3 fw-bold">LOGIN</button>
                    </form>

                    <div class="text-center mt-4">
                        <p>Don't have an account? <a href="/Account/Register" class="text-warning">Register here</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>