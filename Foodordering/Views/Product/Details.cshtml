@{
    ViewData["Title"] = "Product Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row">
        <!-- Image -->
        <div class="col-lg-6">
            <img src="https://picsum.photos/id/201/800/600" class="img-fluid rounded shadow" alt="Cheese Burger">
        </div>

        <!-- Details -->
        <div class="col-lg-6">
            <h2 class="fw-bold">Classic Cheese Burger</h2>
            <h4 class="text-warning">Rs. 450</h4>

            <p class="mt-3">Juicy beef patty with melted cheese, fresh lettuce, tomato, onion, and our special sauce. Served with crispy fries.</p>

            <div class="mb-4">
                <strong>Category:</strong> Burgers<br>
                <strong>Rating:</strong> ★★★★☆ (128 reviews)
            </div>

            <div class="input-group mb-4" style="max-width: 200px;">
                <button class="btn btn-outline-secondary">-</button>
                <input type="text" class="form-control text-center" value="1">
                <button class="btn btn-outline-secondary">+</button>
            </div>

            <button class="btn btn-warning btn-lg px-5" onclick="addToCart()">
                Add to Cart
            </button>

            <a href="/Menu" class="btn btn-outline-secondary btn-lg px-5 ms-3">Back to Menu</a>
        </div>
    </div>
</div>

<script>
    function addToCart() {
        alert("Item added to cart successfully!");
    }
</script>